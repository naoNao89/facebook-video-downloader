{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Facebook Video Downloader",
  "version": "0.1.0",
  "identifier": "com.yourcompany.facebook-video-downloader",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "pnpm run build:wasm:dev && pnpm run build:css",
    "beforeBuildCommand": "pnpm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Facebook Video Downloader",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "focus": true,
        "alwaysOnTop": false,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "plugins": {},
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
